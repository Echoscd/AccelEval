# AccelEval — environment variables
# Copy this file to .env and fill in only the keys you need:
#   cp .env.example .env

# === LLM provider API keys =====================================
# Only fill in the providers you intend to use; leave the rest empty.
# OpenRouter is the default front-end used by the released configs in
# models.yaml; the other entries are for direct-provider routes.

OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# === Hugging Face (optional) ===================================
# Required for `scripts/upload_anon.py` (write access). The download
# script reads from a public dataset by default and does not need a token.
HF_TOKEN=

# === Dataset mirror override (optional) ========================
# scripts/download_data.py defaults to Accel-Eval/AccelEval-data on
# Hugging Face. Override here if you forked the dataset to a different
# namespace.
# ACCELEVAL_HF_REPO=Accel-Eval/AccelEval-data

# === Eval pipeline knobs (optional) ============================
# Comma-separated subset of {small, medium, large}. Leave unset to
# benchmark the largest available scale per task.
# ACCELEVAL_BENCHMARK_SIZES=
# ACCELEVAL_VALIDATE_SIZES=
